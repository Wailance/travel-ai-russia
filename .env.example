PORT=3000

# --- GigaChat: ключ авторизации (рекомендуется) ---
# В личном кабинете https://developers.sber.ru/studio создайте «Ключ авторизации»
# (Authorization key, Base64). Вставьте в GIGACHAT_AUTH_KEY, не путайте с access token.
GIGACHAT_AUTH_KEY=
GIGACHAT_TOKEN=

# OAuth: true — получать access token по ключу авторизации (обычный режим)
# false — GIGACHAT_TOKEN используется напрямую как access token (краткоживущий)
GIGACHAT_USE_OAUTH=true
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1/chat/completions
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_INSECURE_TLS=true

# Локальная проверка UI без GigaChat (базовый маршрут-заглушка)
GIGACHAT_DEMO_MODE=false

FRONTEND_ORIGIN=https://wailance.github.io
